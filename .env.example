# Express Server Settings
PORT=3000

# Discord Bot Credentials
# Obtain your Bot Token from https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# Discord Channel settings
# The ID of the Discord channel where applications should be sent
DISCORD_CHANNEL_ID=YOUR_DISCORD_CHANNEL_ID_HERE

# (Optional) Staff Role ID
# The ID of the staff role. If set, only users with this role can approve or reject applications.
# Leave blank to allow anyone with administrator permissions or anyone in the channel to interact.
DISCORD_STAFF_ROLE_ID=
